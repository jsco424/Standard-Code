drop table if exists u_{owner}.temp_performance_geo_table_{run_id};
create table u_{owner}.temp_performance_geo_table_{run_id} as
select
      A.datepartition
     ,header.memberid as member_id 
     ,cast(regexp_replace(A.campaigngroupurn,'urn:li:sponsoredCampaignGroup:','') as int) as campaigngroupid
	 ,name as campaign_group_name
     ,cast(regexp_replace(A.campaignurn,'urn:li:sponsoredCampaign:','') as int) as campaignid
     ,B.campaign_name
     ,cast(regexp_replace(A.creativeurn,'urn:li:sponsoredCreative:','') as int) as creativeid
     ,campaigntype
     ,case cast(B.campaign_type_info.id as varchar)
        when '5' then 'Text Ad'
        when '14' then 'Sponsored Content'
        when '15' then 'Message Ad'
        when '22' then 'Dynamic Ad'
        else cast(B.campaign_type_info.id as varchar)
      end as campaign_type
     ,B.cost_type as buy_type     
     ,case when impressions>0 then 1 else 0 end as reach
     ,sum(costinlocalcurrency) as cost_local
     ,sum(costinusd) as cost_usd
     ,sum(impressions) as impressions
     ,sum(clicks) as clicks
     ,sum(totalengagements) as totalengagements
     ,sum(otherengagements) as otherengagements
     ,sum(oneclickleads) as oneclickleads
     ,sum(oneclickleadformopens) as oneclickleadformopens
     ,sum(opens) as opens
     ,sum(sends) as sends
     ,sum(videoviews) as videoviews
     ,sum(videocompletions) as videocompletions
from u_adsreporting.engagement_tracking_metrics                                      A
     inner join foundation_lms_mp.dim_sas_campaign                                   B on cast(regexp_replace(A.campaignurn,'urn:li:sponsoredCampaign:','') as int) = B.campaign_id 
     inner join prod_sas.campaign_groups                                             C on cast(regexp_replace(A.campaigngroupurn,'urn:li:sponsoredCampaignGroup:','') as int) = c.campaign_group_id

