-- Region Query

drop table if exists u_insshare.temp_performance_region_country_state_{run_id};
create table u_insshare.temp_performance_region_country_state_{run_id} as
with data as (
  select
      CAST(SUBSTR(b.datepartition,1,10) AS DATE) as dt
    , case
        when geo.countryisocode in ('US','VI','PR','GR','MP','AS') then geo.countryisocode
        when c.state_abrv = split_part(geo.admindivision1isocode,'-',2) then 'US'
        else 'Unmapped'
      end as country_name
    , case
        when geo.countryisocode in ('VI','PR','GR','MP','AS') then geo.countryisocode
        else coalesce(c.state,'Unmapped')
      end as state_name
    , campaignid
    , sum(cost_usd) as cost_usd
  from foundation_core_entity_mp.dim_member_all a
  inner join u_{owner}.temp_performance_geo_table_{run_id} b
    on a.member_id = b.member_id
  left join stz_derived_mp.stz_derived_taxonomy_geo_entities geo
    on a.admin_division_2_id = geo.id
   and geo.entitytype in ('ADMIN_DIVISION_2')
  left join (
    select distinct state, state_abrv, country
    from u_{owner}.region_map_table_{run_id}
  ) c
    on split_part(geo.admindivision1isocode,'-',2) = c.state_abrv
  where 1=1
  group by 1,2,3,4
)
select
    dt
  , case
      when country_name = 'US' then 'United States'
      when country_name = 'VI' then 'US Virgin Island'
      when country_name = 'PR' then 'Puerto Rico'
      when country_name = 'GR' then 'Guam'
      when country_name = 'MP' then 'Northern Mariana Islands'
      when country_name = 'AS' then 'American Samoa'
      else country_name
    end as country_name
  , case
      when state_name = 'VI' then 'US Virgin Island'
      when state_name = 'PR' then 'Puerto Rico'
      when state_name = 'GR' then 'Guam'
      when state_name = 'MP' then 'Northern Mariana Islands'
      when state_name = 'AS' then 'American Samoa'
      else state_name
    end as state_name
  , campaignid
  , cost_usd
from data
order by 1,2,3;


