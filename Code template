CREATE TABLE IF NOT EXISTS u_${your ldap|help:ex: anshukla|type:raw}.sna_industry_distribution_target AS
with member_industry as(
  select
    distinct aa.member_id
    ,ind.l1_industry_name as industry_group_name
  from u_gsoins.lms_app_audienceanalyzer_array aa
  cross join unnest(aa.l1_industries) as f (ind_group_id)
