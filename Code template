CREATE TABLE IF NOT EXISTS u_${your ldap|help:ex: anshukla|type:raw}.ee_campaigns_engaging_target_population AS
SELECT  advertiserid AS engaging_account_id,
        campaignid AS engaging_campaign_id
FROM tracking_column.adclickevent
WHERE TRUE
AND status = 1
AND clicktype IN (1,2)
AND datepartition BETWEEN
    CONCAT(CAST(DATE_ADD('day',-366,DATE_ADD('day',-1,DATE_TRUNC('month', CURRENT_DATE))) AS VARCHAR),'-00') AND
    CONCAT(CAST(DATE_ADD('day', -1, DATE_TRUNC('month', CURRENT_DATE)) AS VARCHAR),'-00')
