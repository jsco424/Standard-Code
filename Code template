--13
CREATE TABLE IF NOT EXISTS u_${your ldap|help:ex: anshukla|type:raw}.engaging_campaigns AS
SELECT  
    campaignid AS campaign_id
FROM tracking_column.adclickevent
WHERE TRUE
AND clicktype IN (1,2)
--paid (valid) & viral (unchargeable + viral with no invalid sequence error)
AND (status = 1 OR (status = 4 AND contains(map_keys(validationfailures),'11') = True
                               AND contains(map_keys(validationfailures),'15') = False))
AND DATE(SUBSTR(datepartition,1,10)) BETWEEN -- last 1 year
    DATE_ADD('month',-12,DATE_TRUNC('month',current_date)) AND LAST_DAY_OF_MONTH(DATE_ADD('month', -1, current_date))
AND header__memberid > 0
AND header__memberid IN
  (SELECT member_id FROM u_${your ldap|help:ex: anshukla|type:raw}.expn_target_audience_population_${region|type:raw})
GROUP BY 1;

