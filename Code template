--03
CREATE TABLE IF NOT EXISTS u_${your ldap|help:ex: anshukla|type:raw}.sc_agg_target AS
SELECT  update_id,
        advertiser_id,
        campaign_id,
        objective_type,
        campaigntype,
        campaign_type_int,
        update_type,
        campaign_cost_type,
        ad_format_type,
        product_type,
        publisher,
        SUBSTR(datepartition,1,7) AS yr_mon,
        SUM(revenue) AS revenue,
        SUM(impressions) AS impressions,
        SUM(clicks) AS clicks,
        SUM(totalengagements) AS totalengagements,
        SUM(videoviews) AS videoviews,
        SUM(videoq25completions) AS videoq25completions,
        SUM(videoq75completions) AS videoq75completions,
        SUM(videocompletions) AS videocompletions,
        SUM(cardimpressions) AS cardimpressions,
        SUM(cardclicks) AS cardclicks,
        0 AS form_views,
        0 AS leads,
        0 AS total_conversions,
        0 AS pv_conversions,
        0 AS pc_conversions,
        0 AS opens
