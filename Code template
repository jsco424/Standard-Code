AND datepartition BETWEEN
    CONCAT(CAST(DATE_ADD('day',-366,DATE_ADD('day',-1,DATE_TRUNC('month', CURRENT_DATE))) AS VARCHAR),'-00') AND
    CONCAT(CAST(DATE_ADD('day', -1, DATE_TRUNC('month', CURRENT_DATE)) AS VARCHAR),'-00')
