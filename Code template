    LEFT JOIN
    u_${your ldap|help:ex: anshukla|type:raw}.sna_industry_growth_target G
        ON D.industry_group = G.industry_group
WHERE TRUE
  AND D.industry_group <> 'Unknown'
GROUP BY 1,2,3
ORDER BY 2 DESC;














