    u_metrics.lms_baseline_monthly_sc_union A
  INNER JOIN
    u_${your ldap|help:ex: anshukla|type:raw}.ee_campaigns_engaging_target_population B
  ON A.advertiser_id = B.engaging_account_id AND A.campaign_id = B.engaging_campaign_id
