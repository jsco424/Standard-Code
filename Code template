--02 - Target Growth - Comparing growth of current year VS last year
DROP TABLE IF EXISTS u_${your ldap|help:ex: anshukla|type:raw}.sna_industry_growth_target;
 
--03
CREATE TABLE IF NOT EXISTS u_${your ldap|help:ex: anshukla|type:raw}.sna_industry_growth_target AS
SELECT  industry_group
    , COUNT(CASE WHEN SUBSTR(CAST(created_month AS VARCHAR),1,10) < '${last year|type:raw}' THEN company_id ELSE NULL END) AS count_last_yr
    , COUNT(CASE WHEN SUBSTR(CAST(created_month AS VARCHAR),1,10) BETWEEN '${last year|type:raw}'  AND '${last month|type:raw}'  THEN company_id ELSE NULL END) AS count_this_yr
    , COUNT(CASE WHEN SUBSTR(CAST(created_month AS VARCHAR),1,10) BETWEEN '${last year|type:raw}' AND '${last month|type:raw}' THEN company_id ELSE NULL END)*1.00/
            COUNT(CASE WHEN SUBSTR(CAST(created_month AS VARCHAR),1,10) < '${last year|type:raw}'  THEN company_id ELSE NULL END) AS industry_growth

FROM
    (
    SELECT
        II.company_id
        , II.created_month
        , DI.l1_industry_name AS industry_group
    FROM
        (
            SELECT  DC.company_id,
                DATE(FROM_UNIXTIME(DC.created_time/1000)) AS created_month,
        DC.industry_id
        FROM
        (
            select
                member_id
                , f.company_sk as company_id
            from u_gsoins.lms_app_audienceanalyzer_array aa
            cross join unnest(aa.companies) as f (company_sk)
            where member_id in (select member_id from u_${your ldap|help:ex: anshukla|type:raw}.expn_target_audience_population_${country_table | type:raw})
        ) CC
        LEFT JOIN
        foundation_core_entity_mp.dim_company DC
        ON CC.company_id = DC.company_id
        WHERE TRUE
        AND DC.company_id IS NOT NULL
    -- Below filter is applied for the industry specific case of this narrative & can be removed, if required
        GROUP BY 1,2,3
        ) II
        INNER JOIN u_gsoins.std_industry_mapping_v2 DI
    ON II.industry_id = DI.industry_id
    WHERE TRUE
    AND lower(DI.status) = 'active'
    GROUP BY 1,2,3
    )
GROUP BY 1
ORDER BY 4 DESC
;

--04
-- Output - industry_distribution
SELECT  D.industry_group
    , D.audience_percentage AS "Member Count %"
    , COALESCE(G.industry_growth,0.00) AS "Company Growth %"
FROM
