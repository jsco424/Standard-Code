--16
WITH funnel_product_master AS
(
  SELECT  (CASE
            WHEN objective_type = 'BRAND_AWARENESS' THEN 'AWARENESS (BRANDING)'
            WHEN objective_type = 'ENGAGEMENT' THEN 'CONSIDERATION (ENGAGEMENT)'
            WHEN objective_type = 'CREATIVE_ENGAGEMENT' THEN 'CONSIDERATION (ENGAGEMENT)'
            WHEN objective_type = 'VIDEO_VIEW' THEN 'AWARENESS (BRANDING)'
            WHEN objective_type = 'WEBSITE_VISIT' THEN 'CONSIDERATION (ENGAGEMENT)'
            WHEN objective_type = 'WEBSITE_TRAFFIC' THEN 'CONSIDERATION (ENGAGEMENT)'
            WHEN objective_type = 'LEAD_GENERATION' THEN 'CONVERSION'
            WHEN objective_type = 'WEBSITE_CONVERSION' THEN 'CONVERSION'
            WHEN objective_type = 'JOB_APPLICANT' THEN 'CONVERSION'
            ELSE objective_type
          END) AS funnel_type,
          (CASE
            WHEN ad_format_type = 'SPONSORED_STATUS_UPDATE' THEN 'STATUS_UPDATE'
            WHEN ad_format_type = 'SPONSORED_UPDATE_CAROUSEL' THEN 'CAROUSEL'
            WHEN ad_format_type = 'SPONSORED_VIDEO' THEN 'VIDEO'
            WHEN ad_format_type LIKE '%JOB%' THEN 'JOBS'
            WHEN ad_format_type = 'SPONSORED_INMAILS' THEN 'INMAIL'
            WHEN ad_format_type = 'SPONSORED_MESSAGE' THEN 'INMAIL'
            WHEN ad_format_type LIKE '%WHITEPAPER%' THEN 'WHITEPAPER'
            WHEN ad_format_type = 'TEXT_AD' THEN 'TEXT_AD'
            WHEN ad_format_type LIKE '%SPOTLIGHT%' THEN 'SPOTLIGHT_DYNAMIC_AD'
            WHEN ad_format_type LIKE '%FOLLOW_COMPANY%' THEN 'FOLLOW_COMPANY_DYNAMIC_AD'
            ELSE ad_format_type
          END) AS product_type,
          SUM(impressions) AS impressions,
          -- SUM(clicks) AS clicks,
          SUM(totalengagements) AS totalengagements,
          SUM(videoviews) AS videoviews,
          SUM(cardimpressions) AS cardimpressions,
          SUM(cardclicks) AS cardclicks,
          SUM(opens) AS opens,
          SUM(form_views) AS form_views,
          SUM(leads) AS leads
          -- SUM(revenue) AS revenue        
  FROM u_${your ldap|help:ex: anshukla|type:raw}.funnel_product_base
  GROUP BY 1,2
)

SELECT funnel_type,
       product_type,
      (CASE
        WHEN funnel_type = 'AWARENESS (BRANDING)' AND product_type = 'STATUS_UPDATE'
          THEN SUM(totalengagements)*100.00/SUM(impressions)
        WHEN funnel_type = 'AWARENESS (BRANDING)' AND product_type = 'CAROUSEL'
          THEN SUM(totalengagements + cardclicks)*100.00/SUM(impressions)
        WHEN funnel_type = 'CONSIDERATION (ENGAGEMENT)' AND product_type <> 'CAROUSEL'
          THEN SUM(totalengagements)*100.00/SUM(impressions)
        WHEN funnel_type = 'CONSIDERATION (ENGAGEMENT)' AND product_type = 'CAROUSEL'
          THEN SUM(totalengagements + cardclicks)*100.00/SUM(impressions)
      ELSE NULL END) AS engagement_rate,
     
      (CASE
        WHEN funnel_type = 'AWARENESS (BRANDING)' AND product_type = 'VIDEO'
          THEN SUM(videoviews)*100.00/SUM(impressions)
      ELSE NULL END) AS view_rate,

      (CASE
        WHEN funnel_type = 'CONSIDERATION (ENGAGEMENT)' AND product_type = 'INMAIL'
          THEN SUM(opens)*100.00/SUM(impressions)
      ELSE NULL END) AS mail_open_rate,
     
      IF(funnel_type = 'CONVERSION', SUM(form_views)*100.00/SUM(impressions), NULL) AS form_open_rate,
      IF(funnel_type = 'CONVERSION', SUM(leads)*100.00/SUM(form_views), NULL) AS lead_rate
     
FROM funnel_product_master
WHERE product_type IN ('STATUS_UPDATE','CAROUSEL','VIDEO','INMAIL')
GROUP BY funnel_type, product_type
ORDER BY funnel_type, product_type
;
















