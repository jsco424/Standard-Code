-- top companies
with t_company as (select
    companies
    ,aa.member_id
    from
    u_gsoins.lms_core_audience_array_union aa
    inner join u_insshare.${topic_name_or_identifier}_weekly_engagements t
    on aa.member_id = t.member_id
    group by 1,2
)
select 
'Companies' as demo_split
,canonical_name
,n_viewer
from
	(select
	company
	,count(distinct member_id) as n_viewer
	from
	t_company
	cross join unnest(companies) as t(company)
	group by 1) a
left join
foundation_core_entity_mp.dim_company b
on a.company = b.company_id
where canonical_name is not null
and n_viewer >= 10
order by 3 desc
;

