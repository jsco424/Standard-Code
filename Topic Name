--Step 1: Filter companies by industry
WITH IndustryFilteredCompanies AS (
    SELECT 
        c.company_id
    FROM foundation_core_entity_mp.dim_company c
    JOIN u_gsoins.std_industry_mapping_v2 i ON c.industry_id = i.industry_id
    WHERE i.industry_name IN (
		'Oil and Gas'
		,'Utilities'
		,'Renewable Energy Semiconductor Manufacturing'
		,'Renewables & Environment'
		
--         'Renewable Energy Equipment Manufacturing',
--         'Services for Renewable Energy',
--         'Renewable Energy Semiconductor Manufacturing',
--         'Renewable Energy Power Generation',
--         'Oil and Gas',
--         'Hydroelectric Power Generation',
--         'Climate Technology Product Manufacturing',
--         'Oil and Coal Product Manufacturing',
--         'Oil Extraction',
--         'Oil, Gas, and Mining',
--         'Mining',
--         'Renewables & Environment',
--         'Solar Electric Power Generation',
--         'Waste Collection',
--         'Waste Treatment and Disposal',
--         'Water Supply and Irrigation Systems',
--         'Water, Waste, Steam, and Air Conditioning Services',
--         'Wholesale Recyclable Materials',
--         'Wind Electric Power Generation'
    )
),

-- Step 2: Aggregate follower counts per month
TotalFollowerCounts AS (
    SELECT
        f.month_sk,
        COUNT(DISTINCT f.member_id) AS monthly_followers
    FROM IndustryFilteredCompanies c
    JOIN u_metrics.company_follower___company_follower_metrics f ON c.company_id = f.company_id
    WHERE f.month_sk BETWEEN '202308' AND '202410'  -- From Feb 2023 to Aug 2024
    GROUP BY f.month_sk
),

-- Step 3: Calculate the monthly growth
MonthlyFollowerGrowth AS (
    SELECT
        month_sk,
        monthly_followers,
        COALESCE(
            monthly_followers - LAG(monthly_followers) OVER (ORDER BY month_sk), 
            monthly_followers
        ) AS follower_growth
    FROM TotalFollowerCounts
)

-- Final Step: Select the results
SELECT
    month_sk AS month,
    monthly_followers,
    follower_growth
FROM MonthlyFollowerGrowth
ORDER BY month;
