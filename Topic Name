--Step 1.3: Create a table with all updates during the time period (not specific to formula 1)
drop table if exists u_insshare.${topic_name_or_identifier}_all_updates;
create table u_insshare.${topic_name_or_identifier}_all_updates as
    select
      upd.company_id
    , ind.company_name
    , ind.industry_id
    , ind.industry_name
    , update_id
    , created_date
    , thread_urn
    , domain_entity_urn
    , is_sponsored
    , regexp_replace(
        lower(
        coalesce(upd.update_text, '')
        ||' '||
        coalesce(upd.article.title, '')
        ||' '||
        coalesce(upd.article.description, '')
        )
       , '[^\p{Alnum}\s:#-'']+',' ' -- Remove everything not (^) alphanumeric (\p{Alnum}), whitespace (\s), a hashtag (#), a dash (-) or an apostrophe (''), and replace it with a white space
        ) as text_string
FROM foundation_lms_mp.dim_nus_company_updates upd
join u_insshare.${topic_name_or_identifier}_industrymaster ind 
    on upd.company_id = ind.company_id
where 1=1
    and created_date between '${long_start_date}' and '${long_end_date}'
    and upd.verb_type IN ('linkedin:post','linkedin:share') --this ensures we only include posts 
;


--Step 1.4: Create a table with all Fomula 1 keywords including company data, industry data and post information
drop table if exists u_insshare.${topic_name_or_identifier}_ind_upd;
create table u_insshare.${topic_name_or_identifier}_ind_upd as
select
      company_name
    , company_id
    , industry_name
    , industry_id
    , update_id
    , created_date
    , content_keyword
    , is_sponsored
    , text_string
    , thread_urn
    , content_language
from u_insshare.${topic_name_or_identifier}_all_updates updates
         CROSS JOIN u_insshare.${topic_name_or_identifier}_topicmaster as topic_key
where 1=1
  and REGEXP_LIKE(lower(text_string) , CONCAT('(^| )', lower(topic_key.content_keyword), '( |$)'))
;

--Step 1.5: Create a table with unique update_id and created_date 
--EXPLANATION: the u_insshare.${topic_name_or_identifier}_ind_upd table can create duplications due to the content_keyword field (one post can have multiple keywords)
--This means that running engagement code directly on u_insshare.${topic_name_or_identifier}_ind_upd can duplicate engagement
--Use u_insshare.${topic_name_or_identifier}_filtered_update_ids if you need to see engagement uplifts or anything where unique posts are important.
--Use u_insshare.${topic_name_or_identifier}_ind_upd if you need to look at keyword performance, language or anything else
drop table if exists u_insshare.${topic_name_or_identifier}_filtered_update_ids;
create table u_insshare.${topic_name_or_identifier}_filtered_update_ids as
SELECT distinct 
        industry_id
      , industry_name
      , company_id
      , update_id
      , created_date
FROM u_insshare.${topic_name_or_identifier}_ind_upd
;

