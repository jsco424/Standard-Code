--Step 2.1: Create weekly engagement table - this sets us up for the output in the slide
drop table if exists u_insshare.${topic_name_or_identifier}_weekly_engagements;
create table u_insshare.${topic_name_or_identifier}_weekly_engagements as 
select 
      member_id
    , date_trunc('week', date(substr(engs.datepartition,1,10))) as week
    , sum(clicks_count+likes_count+comments_count+shares_count) as engagements
from  foundation_lms_mp.agg_daily_company_updates_actions as engs
inner join u_insshare.${topic_name_or_identifier}_filtered_update_ids upd --note we are using the unique update_id table
  on engs.update_id = upd.update_id
--inner join u_insshare.${topic_name_or_identifier}_${region_name}_audience_members aud 
--  on aud.member_id = engs.member_id 
where 1=1 
      and upd.created_date between '${long_start_date}' and '${long_end_date}'
      and engs.datepartition between '${long_start_date}' and '${long_end_date}'
group by 1,2
;


------=========------ THIS IS YOUR OUTPUT FOR THE SLIDE ------=========--------====

select distinct 
		  week
		, 1.0 * engagements / first_value(engagements) over (order by week) as indexed_engagements
from u_insshare.${topic_name_or_identifier}_weekly_engagements
order by 1 asc
;

