inner join u_insshare.${run_id}__custom_target_audience c
  on b.header__memberid = c.member_id
-- where cast(b.datepartition as date) between cast(${start_date} as date) and cast(${end_date} as date)-- replace dates
where 1=1
-- and datepartition between '2024-01-01' and '2024-03-30'
-- and datepartition between '2024-04-01' and '2024-06-31'
-- and datepartition between '2025-01-01' and '2025-03-30'
-- and datepartition between '2025-07-01' and '2025-09-30'
   and datepartition between '2025-12-01' and '2025-12-31'
  -- valid or unchargeable (see below)
  and lower(status) in ('valid','unchargeable')
group by 1,2,3,4,7
;


