-- --SOV breakout
--output 1
with peers as (
    select
           mth,
           approx_percentile(SOV,.75) as top_performing_SOV,
           approx_percentile(SOV,.5) as median_SOV,
           approx_percentile(SOV,.25) as low_perf_SOV
    from  u_insshare.${run_id}_paid_impressions
    where target_peers in ('peer')
    group by 1
    order by 1 asc),

     client as (select 
                       mth,
                       -- companypage_id,
                       sum(brand_imps) as imps,
                       company_grouping,
                       SOV as client_SOV
                from  u_insshare.${run_id}_paid_impressions
                where target_peers in ('client')
                group by 1,3,4
                order by 1 asc)

select 
        -- 'Global' as region,   -- update this for global audience
        'US' as region, 
        'Both Onplatform & LAN' as LAN, -- update this when LAN is excluded
        p.mth,
        c.imps as client_imp,
       top_performing_SOV,
       median_SOV,
       low_perf_SOV,
       client_SOV
from  peers p
          inner join client c on p.mth = c.mth
order by 1 asc
;

--output 2
SELECT
    'US' AS region,
    'Both Onplatform & LAN' AS LAN,
    'Dec2025' AS time_period,
    approx_percentile(SOV, 0.75) AS top_performing_SOV,
    approx_percentile(SOV, 0.5) AS median_SOV,
    approx_percentile(SOV, 0.25) AS low_perf_SOV,
    (SELECT SOV FROM u_insshare.open_ai_paid_impressions_2 WHERE target_peers IN ('client') LIMIT 1) AS client_SOV,
    (SELECT SUM(brand_imps) FROM u_insshare.open_ai_paid_impressions_2 WHERE target_peers IN ('client')) AS client_imp
FROM u_insshare.open_ai_paid_impressions_2
WHERE target_peers IN ('peer')
ORDER BY 1 ASC;


