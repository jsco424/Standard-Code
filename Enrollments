/* ============================================================
   AGE BREAKS (carry school_group through age temp + outputs)
   NOTE: pulls school_group from {ldap}_enrollments_cliff_main_table_temp
   ============================================================ */

drop table if exists u_insshare.{ldap}_enrollments_cliff_age_brackets_temp;
create table u_insshare.{ldap}_enrollments_cliff_age_brackets_temp as
select
  case
    when year(current_date) - yearborn between 18 and 24 then '18 - 24'
    when year(current_date) - yearborn between 25 and 34 then '25 - 34'
    when year(current_date) - yearborn between 35 and 54 then '35 - 54'
    when year(current_date) - yearborn >= 55 then '55+'
  end as cmt_age_bucket
, geostddata.countrycode
, memberid
from data_derived.standardization_member_yearborn
where yearborn is not null
  and year(current_date) - yearborn >= 18
;

drop table if exists u_insshare.{ldap}_enrollments_cliff_main_table_age_temp;
create table u_insshare.{ldap}_enrollments_cliff_main_table_age_temp as
select distinct
      enr.education_id
    , enr.member_id
    , enr.mem_type
    , age.cmt_age_bucket
    , enr.school_name
    , enr.education_type as school_type
    , enr.school_geo
    , enr.subvertical
    , enr.organization_id as company_id
    , co.school_group
    , enr.degree_name as degree_type
    , coalesce(parent_field_of_study, 'Unknown') as parent_field_of_study
    , coalesce(enr.field_of_study, 'Unknown') as field_of_study
    , enr.enroll_date as enrolldate
    , year(enr.enroll_date) as enrollyear
    , month(enr.enroll_date) as enrollmonth
from u_edu.edu_enrollments_std enr
join u_insshare.{ldap}_enrollments_cliff_age_brackets_temp age
  on enr.member_id = age.memberid
join u_insshare.{ldap}_enrollments_cliff_main_table_temp co
  on  co.member_id = enr.member_id
  and co.education_id = enr.education_id
;

