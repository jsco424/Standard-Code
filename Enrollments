drop table if exists u_insshare.{ldap}_enrollments_cliff_main_table_temp;
create table u_insshare.{ldap}_enrollments_cliff_main_table_temp as
select distinct
      enr.education_id
     ,enr.member_id
     ,enr.mem_type
     ,enr.school_name
     ,enr.school_type
     ,enr.school_geo
     ,enr.subvertical
	 ,enr.organization_id as company_id
	 ,case
          when enr.organization_id in (3323650,11248046) then 'Cornell Johnson'
          when enr.organization_id in (3195) then 'Kellog MBA'
          when enr.organization_id in (2781064) then 'Kellog Exec Ed'
          when enr.organization_id in (2891086,3194,15100353) then 'Northwestern Masters'
          when enr.organization_id in (3196) then 'Northwestern Undergrad'
          when enr.organization_id in (4867,9220773) then 'Harvard Business School'
          when enr.organization_id in (1375913) then 'Harvard Exec Ed'
          when enr.organization_id in (17473) then 'Walden'
          when enr.organization_id in (100302) then 'Chamberlain'
          when enr.organization_id in (250372,510837) then 'Ross School of Medicine'
          when enr.organization_id in (2442373) then 'American U of Caribbean'
          when enr.organization_id in (14084) then 'WGU'
          when enr.organization_id in (4734) then 'University of Arizona'
          when enr.organization_id in (210965) then 'National University'
          else 'Other'
      end as school_group
     ,enr.degree_name as degree_type
	 ,coalesce(parent_field_of_study, 'Unkown') as parent_field_of_study
     ,coalesce(enr.Field_of_Study, 'Unkown') as Field_of_Study
     ,enr.enroll_date as enrolldate
     ,year(enr.enroll_date) as enrollyear
     ,month(enr.enroll_date) as enrollmonth
     ,influenced_student_exposed
     ,influenced_student_clicked
     ,influenced_student_lgf_lead
from  u_edu.edu_enrollments_std_march_24 enr
      left join u_edu.edu_influenced_student_march_24 inf on enr.member_id=inf.member_id and enr.education_id=inf.education_id
where enr.organization_id in (3323650,11248046,3195,2781064,2891086,3194,15100353,3196,4867,9220773,1375913,17473,100302,250372,510837,2442373,14084,4734,210965)      
;

