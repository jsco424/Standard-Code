/* ============================================================
   CERTS + school_group
   ============================================================ */

with member_primary_school as (
  select member_id, school_group
  from (
    select member_id, school_group, enrolldate,
           row_number() over (partition by member_id order by enrolldate asc) rn
    from u_insshare.{ldap}_enrollments_cliff_main_table_temp
  )
  where rn = 1
)
SELECT 
    ctf.authority
  , ctf.name
  , audience.cmt_age_bucket
  , s.school_group
  , COUNT(DISTINCT CASE WHEN ctf.start_year = 2023 THEN c.member_id END) AS num_members_2023
  , COUNT(DISTINCT CASE WHEN ctf.start_year = 2024 THEN c.member_id END) AS num_members_2024
  , (CASE
        WHEN COUNT(DISTINCT CASE WHEN ctf.start_year = 2023 THEN c.member_id END) = 0
        THEN NULL
        ELSE (COUNT(DISTINCT CASE WHEN ctf.start_year = 2024 THEN c.member_id END) * 1.0
              / COUNT(DISTINCT CASE WHEN ctf.start_year = 2023 THEN c.member_id END))
     END) AS diff_perc
FROM foundation_core_entity_mp.dim_member_all c
inner join u_insshare.{ldap}_enrollments_cliff_age_brackets_temp audience on c.member_id = audience.memberid
inner join member_primary_school s on s.member_id = c.member_id
CROSS JOIN UNNEST(c.certifications) AS t(ctf)
WHERE ctf.start_year IS NOT NULL
  and country.country_code = 'us'
GROUP BY 1,2,3,4
HAVING COUNT(DISTINCT CASE WHEN ctf.start_year = 2023 THEN c.member_id END) >= 100
   AND COUNT(DISTINCT CASE WHEN ctf.start_year = 2024 THEN c.member_id END) >= 100
ORDER BY diff_perc DESC
;

with member_primary_school as (
  select member_id, school_group
  from (
    select member_id, school_group, enrolldate,
           row_number() over (partition by member_id order by enrolldate asc) rn
    from u_insshare.{ldap}_enrollments_cliff_main_table_temp
  )
  where rn = 1
)
select
    ctf.start_year
  , audience.cmt_age_bucket
  , s.school_group
  , count(distinct ctf.id) as num_certs
from foundation_core_entity_mp.dim_member_all c
inner join u_insshare.{ldap}_enrollments_cliff_age_brackets_temp audience on c.member_id = audience.memberid
inner join member_primary_school s on s.member_id = c.member_id
cross join unnest(c.certifications) as t(ctf)
where country.country_code = 'us'
  and ctf.start_year >= 2019
group by 1,2,3
;


