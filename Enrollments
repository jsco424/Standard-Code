/* ============================================================
   REGISTRATION (by age bucket) + school_group
   NOTE: assigns each member to ONE school_group (earliest enrolldate)
   ============================================================ */

with member_primary_school as (
  select member_id, school_group
  from (
    select
        member_id
      , school_group
      , enrolldate
      , row_number() over (partition by member_id order by enrolldate asc) as rn
    from u_insshare.{ldap}_enrollments_cliff_main_table_temp
  )
  where rn = 1
)
select 
    date_trunc('year', date(registration_date)) as year
  , s.school_group
  , cmt_age_bucket
  , count(distinct member_id) as mcnt
from (
    select  
        m.member_id
      , a.cmt_age_bucket
      , min(date(from_unixtime(registration_time/1000))) as registration_date
    from foundation_core_entity_mp.dim_member_all m
    join u_insshare.{ldap}_enrollments_cliff_age_brackets_temp a
      on a.memberid = m.member_id
    where country.country_code = 'us'
    group by 1,2
) r
join member_primary_school s
  on s.member_id = r.member_id
where date_trunc('year', date(registration_date)) >= date('2019-01-01')
group by 1,2,3
order by 1,2,3
;


/* ============================================================
   LINKEDIN LEARNING TABLES + school_group
   ============================================================ */

drop table if exists u_insshare.{ldap}_enrollments_cliff_LinkedIn_Learning;
create table if not exists u_insshare.{ldap}_enrollments_cliff_LinkedIn_Learning as
with member_primary_school as (
  select member_id, school_group
  from (
    select member_id, school_group, enrolldate,
           row_number() over (partition by member_id order by enrolldate asc) rn
    from u_insshare.{ldap}_enrollments_cliff_main_table_temp
  )
  where rn = 1
)
select 
    course_title
  , audience.cmt_age_bucket
  , s.school_group
  , cast(count(distinct case
        when partition_date(lsv.datepartition) between date('{start_date_prev}') and date('{end_date_prev}')
        then lsv.learner_urn end) as double) as learners_prev
  , cast(count(distinct case
        when partition_date(lsv.datepartition) between date('{start_date_curr}') and date('{end_date_curr}')
        then lsv.learner_urn end) as double) as learners_current
from u_metrics.learning_session_video_union lsv
join u_metrics.dim_lynda_video v on v.video_id = lsv.video_id
join u_metrics.dim_lynda_course c on c.course_id = v.course_id
join u_insshare.{ldap}_enrollments_cliff_age_brackets_temp audience on lsv.member_id = audience.memberid
join foundation_core_entity_mp.dim_member_all m on audience.memberid = m.member_id
join member_primary_school s on s.member_id = m.member_id
where true 
  and country.country_code = 'us'
  and app = 'Learning App' 
  and lsv.member_id > 0
group by 1,2,3
order by 2 desc
;

drop table if exists u_insshare.{ldap}_enrollments_cliff_LinkedIn_Learning_WoW;
create table if not exists u_insshare.{ldap}_enrollments_cliff_LinkedIn_Learning_WoW as
with member_primary_school as (
  select member_id, school_group
  from (
    select member_id, school_group, enrolldate,
           row_number() over (partition by member_id order by enrolldate asc) rn
    from u_insshare.{ldap}_enrollments_cliff_main_table_temp
  )
  where rn = 1
)
select
    date_trunc('month', partition_date(datepartition)) as usage_month
  , audience.cmt_age_bucket
  , s.school_group
  , approx_distinct(learner_urn) as learners
from u_metrics.learning_session_video_union lsv
inner join u_insshare.{ldap}_enrollments_cliff_age_brackets_temp audience on lsv.member_id = audience.memberid
inner join foundation_core_entity_mp.dim_member_all m on audience.memberid = m.member_id
inner join member_primary_school s on s.member_id = m.member_id
where partition_date(datepartition) >= date_add('month', -24, date_trunc('month', current_date)) 
  and app = 'Learning App'
  and country.country_code = 'us'
group by 1,2,3
;

