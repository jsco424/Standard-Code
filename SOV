-- --SOV breakout
--output 1
with peers as (
    select
           mth,
           approx_percentile(SOV,.75) as top_performing_SOV,
           approx_percentile(SOV,.5) as median_SOV,
           approx_percentile(SOV,.25) as low_perf_SOV
    from  ${ldap |type:varchar}.{run_id}_paid_impressions
    where target_peers in ('peer')
    group by 1
    order by 1 asc),

     client as (select 
                       mth,
                       -- companypage_id,
                       sum(brand_imps) as imps,
                       company_grouping,
                       SOV as client_SOV
                from  ${ldap |type:varchar}.{run_id}_paid_impressions
                where target_peers in ('client')
                group by 1,3,4
                order by 1 asc)

select 
        -- 'Global' as region,   -- update this for global audience
        'US' as region, 
        'Both Onplatform & LAN' as LAN, -- update this when LAN is excluded
        p.mth,
        c.imps as client_imp,
       top_performing_SOV,
       median_SOV,
       low_perf_SOV,
       client_SOV
from  peers p
          inner join client c on p.mth = c.mth
order by 1 asc
;

--output 2
    select
          -- 'Global' as region,    -- update this for global audience
          'US' as region, 
          'Both Onplatform & LAN' as LAN, -- update this when LAN is excluded
          'July1_Sep30_2025' as time_period, -- update this when you change the date range
           approx_percentile(SOV,.75) as top_performing_SOV,
           approx_percentile(SOV,.5) as median_SOV,
           approx_percentile(SOV,.25) as low_perf_SOV,
           (select SOV as client_SOV  from  ${ldap |type:varchar}.{run_id}_paid_impressions_2 where target_peers in ('client')) as client_SOV,
         (select sum(brand_imps) as imp from  ${ldap |type:varchar}.{run_id}_paid_impressions_2 where target_peers in ('client')) as client_imp
    from  ${ldap |type:varchar}.{run_id}_paid_impressions_2
    where target_peers in ('peer')
    -- group by 1
    order by 1 asc
  ;  


