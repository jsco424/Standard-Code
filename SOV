--create campaign list
drop table if exists u_insshare.${run_id}_sov_campaign_list;
create table u_insshare.${run_id}_sov_campaign_list as
select distinct
   b.company_grouping
  ,a.campaign_id
  ,b.target_peers
from foundation_lms_mp.dim_sas_campaign a
inner join u_insshare.${run_id}_company_peer_table  b
-- on a.company_id = b.companypage_id JOINING ON COMPANY ID CAUSES DUPLICATIONS - ty Gabriel!!!
on a.campaign_id = b.campaign_id
where 1=1
  and campaign_type_info.id in (5,14,15,22) -- sponsored content, Message_Ads, dynamic, text ads aka direct ads
    and (product_type is null or product_type = 'MARKETING_SOLUTIONS')
  --- exclude talent and job ads (comment this out if you want to include all ad tups)
  and (objective_type not in ('TALENT_LEAD','JOB_APPLICANT') or objective_type is null)
  -- AND a.campaign_id IN (SELECT campaign_id FROM foundation_lms_mp.agg_f_sas_campaign_summary
    --                      WHERE li_business_vertical IN ('LMS-TCM') AND company_id IN (${company_id},${peer_ids})) --include only LMS and LMS-TCM campaigns & exclude LTS
;

