-- and datepartition between '2025-01-01' and '2025-03-30'
-- and datepartition between '2025-07-01' and '2025-09-30'
   and datepartition between '2024-07-01' and '2024-09-30'
  -- valid or unchargeable (see below)
  and lower(status) in ('valid','unchargeable')
group by 1,2,3,4,7
;


