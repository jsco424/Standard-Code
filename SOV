---- Get impressions for on-platform impressions

insert into ${ldap |type:varchar}.{run_id}_sov_lms_data_raw
select
  -- a.company_name
  company_grouping
  -- ,a.companypage_id
  -- ,a.company_id
  ,a.campaign_id
  ,b.datepartition
  ,b.header__memberid as member_id
  ,coalesce(sum(1),0) as imps
  ,1 as sponsored
  ,a.target_peers
from tracking_column.adimpressionevent b
inner join u_insshare.${run_id}_sov_campaign_list a
  on a.campaign_id=b.campaignid
inner join ${ldap |type:varchar}.{run_id}_custom_target_audience c
  on b.header__memberid = c.member_id
-- where cast(b.datepartition as date) between cast(${start_date} as date) and cast(${end_date} as date) -- replace dates
where 1=1
-- and datepartition between '2024-01-01' and '2024-03-30'
-- and datepartition between '2024-04-01' and '2024-06-31'
-- and datepartition between '2025-01-01' and '2025-03-30'
-- and datepartition between '2025-07-01' and '2025-09-30'
and datepartition between '2024-07-01' and '2024-09-30'
  -- 1 is paid/valid and 4 is viral/unchargable  (see below)
  and (statusint=1 OR
--includes VIRAL imps (see comments in header above for detailed explanation on how to calculate viral)
  (statusint=4 and contains(map_keys(validationfailures),'11')=True and contains(map_keys(validationfailures),'15')=False))
  -- text ads, sponsored content, Message_Ads, dynamic (see below)
  and b.campaigntypeint in (5,14,15,22)
group by 1,2,3,4,7
;


