--paid impressions

drop table if exists  ${ldap |type:varchar}.{run_id}_paid_impressions;
create table  ${ldap |type:varchar}.{run_id}_paid_impressions as (
    select analysis
         , mth
         -- , companypage_id
         -- , company_name
         , company_grouping
         , target_peers
         , reach
         , brand_imps
         , cast(brand_imps as double) / sum(brand_imps) over (partition by (mth)) as SOV
    from (
             select 'reach and frequency'                                 as analysis
                  , date_trunc('month', date(substr(datepartition,1,10))) as mth
                  -- , companypage_id
                  -- , company_name
                  , company_grouping
                  , target_peers
                  , sum(imps)                                             as brand_imps
                  , count(distinct member_id)                             as reach
                  , rank() over (partition by 'reach and frequency' order by sum(imps) desc) as rnk
             from  ${ldap |type:varchar}.{run_id}_sov_lms_data_raw
             group by 1, 2, 3,4
         ) a
             cross join
         (
             select count(distinct member_id) as total_audience_size
             from  ${ldap |type:varchar}.{run_id}_custom_target_audience
         ) b
    group by 1, 2, 3, 4, 5, 6
);


drop table if exists  ${ldap |type:varchar}.{run_id}_paid_impressions_2;
create table  ${ldap |type:varchar}.{run_id}_paid_impressions_2 as (
    select analysis
         -- , mth
         -- , companypage_id
         -- , company_name
         , company_grouping
         , target_peers
         , reach
         , brand_imps
         , cast(brand_imps as double) / sum(brand_imps) over () as SOV
    from (
             select 'reach and frequency'                                 as analysis
                  -- , date_trunc('month', date(substr(datepartition,1,10))) as mth
                  -- , companypage_id
                  -- , company_name
                  , company_grouping
                  , target_peers
                  , sum(imps)                                             as brand_imps
                  , count(distinct member_id)                             as reach
                  , rank() over (partition by 'reach and frequency' order by sum(imps) desc) as rnk
             from  ${ldap |type:varchar}.{run_id}_sov_lms_data_raw
             group by 1, 2, 3
         ) a
             cross join
         (
             select count(distinct member_id) as total_audience_size
             from  ${ldap |type:varchar}.{run_id}_custom_target_audience
         ) b
    group by 1, 2, 3, 4, 5
);

select * from  ${ldap |type:varchar}.{run_id}_paid_impressions;

